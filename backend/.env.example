# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (default). To switch databases, change only this URL..
# SQLite (dev):
DATABASE_URL=sqlite:///./ada_east.db
#DATABASE_URL=postgresql://postgres:password@localhost:5432/ada_east_filing

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a long random value for production, e.g. from a password manager.
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Ada East District Assembly – Digital Filing System
APP_VERSION=1.0.1
DEBUG=True
